# ============================================================================
# ML OCR Server - Environment Configuration Template
# ============================================================================
# COPY THIS FILE TO .env AND FILL IN YOUR ACTUAL VALUES
# DO NOT commit the actual .env file to version control
# ============================================================================

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
# ML Server host and port
ML_SERVER_HOST=127.0.0.1
ML_SERVER_PORT=8000

# ============================================================================
# TESSERACT OCR CONFIGURATION
# ============================================================================
# Windows Tesseract installation path (default installation location)
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_TESSDATA_PREFIX=C:\Program Files\Tesseract-OCR\tessdata

# Language configuration (Khmer + English)
TESSERACT_LANG=khm+eng

# For Linux/MacOS, use these paths instead:
# TESSERACT_CMD=/usr/bin/tesseract
# TESSERACT_TESSDATA_PREFIX=/usr/share/tesseract-ocr/4.00/tessdata

# ============================================================================
# YOLO MODEL CONFIGURATION
# ============================================================================
# Path to YOLO model weights (relative to utils/YoloKh/)
YOLO_MODEL_PATH=utils/YoloKh/best.pt

# Detection confidence threshold (0.0 to 1.0)
CONFIDENCE_THRESHOLD=0.5

# ============================================================================
# GOOGLE GEMINI VISION API CONFIGURATION (Optional)
# ============================================================================
# Get your API key from: https://ai.google.dev/
# 1. Go to Google AI Studio (https://aistudio.google.com/app/apikey)
# 2. Click "Create API key in new project"
# 3. Copy the generated API key below
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================================
# BACKEND API CONFIGURATION
# ============================================================================
# Backend server URLs (for callbacks and integration)
BACKEND_URL=http://localhost:3000
BACKEND_UPLOAD_URL=http://127.0.0.1:3000/images/upload

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# ============================================================================
# MODEL SELECTION DEFAULTS
# ============================================================================
# Default detection model: doctr or yolo
DEFAULT_DETECTION_MODEL=doctr

# Default recognition model: tesseract, kiriocr, or gemini
DEFAULT_RECOGNITION_MODEL=tesseract

# Detection granularity: word or line
DEFAULT_DETECTION_GRANULARITY=word

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Enable/disable specific OCR engines
ENABLE_TESSERACT=True
ENABLE_KIRIOCR=False  # Set to True if kiri-ocr is installed
ENABLE_YOLO=True  # Set to True if YOLO weights are available
ENABLE_GEMINI=False  # Set to True to enable Gemini Vision API (requires GEMINI_API_KEY)

# ============================================================================
# PERFORMANCE & DEBUG
# ============================================================================
# Debug mode
DEBUG_MODE=False
DEBUG_SAVE_IMAGES=False  # Save cropped/preprocessed images for debugging
DEBUG_OCR_DIR=D:/debug_ocr  # Directory to save debug images

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Maximum file upload size (in bytes, default 50MB)
MAX_UPLOAD_SIZE=52428800

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================================================
# SETUP NOTES
# ============================================================================
#
# 1. TESSERACT SETUP:
#    - Download installer: https://github.com/UB-Mannheim/tesseract/wiki
#    - Install with "Additional Language Data"
#    - Enable Khmer (khm) and English (eng) during installation
#    - Add to system PATH: C:\Program Files\Tesseract-OCR\
#
# 2. GEMINI API SETUP (Optional):
#    - Create free account at https://ai.google.dev/
#    - Get API key from https://aistudio.google.com/app/apikey
#    - Install package: pip install google-generativeai
#    - Free tier available (no credit card required)
#    - Set ENABLE_GEMINI=True after adding your API key
#
# 3. KIRIOCR SETUP (Optional):
#    - Install with: pip install kiri-ocr
#    - Better for Khmer text but requires more resources
#    - Set ENABLE_KIRIOCR=True after installation
#
# 4. YOLO SETUP:
#    - Weights file: utils/YoloKh/best.pt
#    - Alternative to DocTR for text detection
#    - Set DEFAULT_DETECTION_MODEL=yolo to use YOLO instead of DocTR
#
# ============================================================================
